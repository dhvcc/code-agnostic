{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "mcp_servers"],
  "properties": {
    "spec_version": { "const": "v1" },
    "mcp_servers": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/server"
      }
    }
  },
  "$defs": {
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client_id", "client_secret"],
      "properties": {
        "client_id": { "type": "string", "minLength": 1 },
        "client_secret": { "type": "string", "minLength": 1 },
        "scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "token_endpoint": { "type": "string", "minLength": 1 }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["stdio", "http", "oauth"]
        },
        "command": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "url": { "type": "string", "minLength": 1 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "auth": { "$ref": "#/$defs/auth" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "stdio" }
            }
          },
          "then": {
            "required": ["command"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["http", "oauth"]
              }
            }
          },
          "then": {
            "required": ["url"]
          }
        }
      ]
    }
  }
}
