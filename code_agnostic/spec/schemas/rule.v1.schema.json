{
  "$id": "https://raw.githubusercontent.com/dhvcc/code-agnostic/main/code_agnostic/spec/schemas/rule.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "kind"],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "spec_version": { "const": "v1" },
    "kind": { "const": "rule" },
    "description": { "type": "string" },
    "globs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "always_apply": { "type": "boolean" },
    "x-cursor": { "type": "object" },
    "x-codex": { "type": "object" },
    "x-opencode": { "type": "object" }
  }
}
